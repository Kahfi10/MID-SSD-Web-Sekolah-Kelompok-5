                  "    pm.expect(json).to.be.an('array');",
                  "    pm.expect(json.length).to.equal(0);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/users/api/search?q=a",
