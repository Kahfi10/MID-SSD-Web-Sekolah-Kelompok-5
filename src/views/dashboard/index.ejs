<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-1">Dashboard</h4>
        <p class="text-muted mb-0" style="font-size:0.9rem;">Selamat datang kembali, <%= user.full_name %></p>
    </div>
    <span class="text-muted" style="font-size:0.85rem;" id="liveClock"></span>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-4 col-lg-2">
        <div class="stat-card">
            <div class="stat-icon"><i class="bi bi-people-fill"></i></div>
            <div class="stat-value counter" data-target="<%= studentCount %>">0</div>
            <div class="stat-label text-muted">Siswa Aktif</div>
        </div>
    </div>
    <div class="col-md-4 col-lg-2">
        <div class="stat-card">
            <div class="stat-icon"><i class="bi bi-person-video3"></i></div>
            <div class="stat-value counter" data-target="<%= teacherCount %>">0</div>
            <div class="stat-label text-muted">Guru</div>
        </div>
    </div>
    <div class="col-md-4 col-lg-2">
        <div class="stat-card">
            <div class="stat-icon"><i class="bi bi-door-open-fill"></i></div>
            <div class="stat-value counter" data-target="<%= classCount %>">0</div>
            <div class="stat-label text-muted">Kelas</div>
        </div>
    </div>
    <div class="col-md-4 col-lg-2">
        <div class="stat-card">
            <div class="stat-icon"><i class="bi bi-journal-bookmark-fill"></i></div>
            <div class="stat-value mono-blue counter" data-target="<%= journalCount %>">0</div>
            <div class="stat-label text-muted">Jurnal</div>
        </div>
    </div>
    <div class="col-md-4 col-lg-2">
        <div class="stat-card">
            <div class="stat-icon"><i class="bi bi-exclamation-triangle-fill"></i></div>
            <div class="stat-value counter" data-target="<%= bkCaseCount %>">0</div>
            <div class="stat-label text-muted">Kasus BK Aktif</div>
        </div>
    </div>
    <div class="col-md-4 col-lg-2">
        <div class="stat-card">
            <div class="stat-icon"><i class="bi bi-person-badge-fill"></i></div>
            <div class="stat-value counter" data-target="<%= userCount %>">0</div>
            <div class="stat-label text-muted">Pengguna</div>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-lg-8">
        <div class="card h-100">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h6 class="mb-0">Jurnal Mengajar per Bulan</h6>
                <span class="text-muted" style="font-size:0.8rem;">6 bulan terakhir</span>
            </div>
            <div class="card-body">
                <canvas id="journalChart"></canvas>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card h-100">
            <div class="card-header">
                <h6 class="mb-0">Status Siswa</h6>
            </div>
            <div class="card-body d-flex align-items-center justify-content-center">
                <canvas id="statusChart"></canvas>
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-lg-5">
        <div class="card h-100">
            <div class="card-header">
                <h6 class="mb-0">Siswa per Kelas</h6>
            </div>
            <div class="card-body">
                <canvas id="classChart"></canvas>
            </div>
        </div>
    </div>
    <div class="col-lg-3">
        <div class="card h-100">
            <div class="card-header">
                <h6 class="mb-0">Gender</h6>
            </div>
            <div class="card-body d-flex align-items-center justify-content-center">
                <canvas id="genderChart"></canvas>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card h-100">
            <div class="card-header">
                <h6 class="mb-0">Kasus BK Terbanyak</h6>
            </div>
            <div class="card-body">
                <canvas id="bkChart"></canvas>
            </div>
        </div>
    </div>
</div>

<div class="card mb-4">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h6 class="mb-0">Aktivitas Terbaru</h6>
        <span class="text-muted" style="font-size:0.8rem;"><i class="bi bi-clock"></i> Real-time</span>
    </div>
    <div class="card-body p-0">
        <% if (recentLogs.length > 0) { %>
            <div class="list-group list-group-flush">
                <% recentLogs.forEach(function(log) { %>
                <div class="list-group-item d-flex align-items-center">
                    <div class="d-flex align-items-center justify-content-center me-3 bg-light rounded-circle" style="width:36px;height:36px;flex-shrink:0;">
                        <i class="bi bi-person text-muted" style="font-size:0.9rem;"></i>
                    </div>
                    <div class="flex-grow-1" style="font-size:0.9rem;">
                        <strong><%= log.full_name %></strong>
                        <span class="badge bg-light text-dark border ms-1"><%= log.action %></span>
                        <br>
                        <span class="text-muted" style="font-size:0.8rem;"><%= log.description %></span>
                    </div>
                    <span class="text-muted" style="font-size:0.75rem;white-space:nowrap;margin-left:1rem;">
                        <%= new Date(log.created_at).toLocaleString('id-ID', {hour:'2-digit',minute:'2-digit'}) %>
                    </span>
                </div>
                <% }); %>
            </div>
        <% } else { %>
            <div class="text-center py-5 text-muted">
                <i class="bi bi-inbox" style="font-size:2rem;"></i>
                <p class="mt-2 mb-0">Belum ada aktivitas</p>
            </div>
        <% } %>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const counters = document.querySelectorAll('.counter');
    counters.forEach(counter => {
        const target = parseInt(counter.getAttribute('data-target'));
        const duration = 1000;
        const step = Math.max(1, Math.ceil(target / (duration / 16)));
        let current = 0;
        const update = () => {
            current += step;
            if (current >= target) { counter.textContent = target; return; }
            counter.textContent = current;
            requestAnimationFrame(update);
        };
        update();
    });

    const colors = {
        blue: '#0071e3',
        gray: '#86868b',
        light: '#e8e8ed',
        dark: '#1d1d1f',
        green: '#34c759',
        red: '#ff3b30',
        orange: '#ff9500',
        teal: '#5ac8fa'
    };

    // 1. Journal Bar Chart
    new Chart(document.getElementById('journalChart'), {
        type: 'bar',
        data: {
            labels: [<% journalPerMonth.forEach(function(j) { %>'<%= j.month %>',<% }); %>],
            datasets: [{
                label: 'Jurnal',
                data: [<% journalPerMonth.forEach(function(j) { %><%= j.total %>,<% }); %>],
                backgroundColor: ['#0071e3', '#0071e3', '#0071e3', '#0071e3', '#0071e3', '#0071e3'],
                borderRadius: 6,
                borderSkipped: false
            }]
        },
        options: {
            responsive: true,
            plugins: { legend: { display: false } },
            scales: {
                y: { beginAtZero: true, grid: { color: '#e8e8ed' }, ticks: { color: '#86868b' } },
                x: { grid: { display: false }, ticks: { color: '#86868b' } }
            }
        }
    });

    // 2. Status Donut
    new Chart(document.getElementById('statusChart'), {
        type: 'doughnut',
        data: {
            labels: [<% studentStatus.forEach(function(s) { %>'<%= s.status %>',<% }); %>],
            datasets: [{
                data: [<% studentStatus.forEach(function(s) { %><%= s.total %>,<% }); %>],
                backgroundColor: ['#34c759', '#5ac8fa', '#ff9500', '#ff3b30'],
                borderWidth: 0
            }]
        },
        options: {
            responsive: true, cutout: '65%',
            plugins: { legend: { position: 'bottom', labels: { padding: 12, usePointStyle: true, color: '#86868b' } } }
        }
    });

    // 3. Students per Class (horizontal bar)
    new Chart(document.getElementById('classChart'), {
        type: 'bar',
        data: {
            labels: [<% studentsPerClass.forEach(function(c) { %>'<%= c.class_name %>',<% }); %>],
            datasets: [{
                label: 'Siswa',
                data: [<% studentsPerClass.forEach(function(c) { %><%= c.total %>,<% }); %>],
                backgroundColor: '#86868b',
                borderRadius: 4,
                borderSkipped: false
            }]
        },
        options: {
            indexAxis: 'y', responsive: true,
            plugins: { legend: { display: false } },
            scales: {
                x: { beginAtZero: true, grid: { color: '#e8e8ed' }, ticks: { color: '#86868b' } },
                y: { grid: { display: false }, ticks: { color: '#86868b' } }
            }
        }
    });

    // 4. Gender
    const gData = { labels: [], datasets: [{ data: [], backgroundColor: ['#0071e3', '#ff3b30'], borderWidth: 0 }] };
    <% genderCount.forEach(function(g) { %>
        gData.labels.push('<%= g.gender === "L" ? "Laki-laki" : "Perempuan" %>');
        gData.datasets[0].data.push(<%= g.total %>);
    <% }); %>
    new Chart(document.getElementById('genderChart'), {
        type: 'doughnut', data: gData,
        options: {
            responsive: true, cutout: '60%',
            plugins: { legend: { position: 'bottom', labels: { padding: 10, usePointStyle: true, color: '#86868b' } } }
        }
    });

    // 5. BK Cases
    new Chart(document.getElementById('bkChart'), {
        type: 'polarArea',
        data: {
            labels: [<% casesByType.forEach(function(c) { %>'<%= c.case_type %>',<% }); %>],
            datasets: [{
                data: [<% casesByType.forEach(function(c) { %><%= c.total %>,<% }); %>],
                backgroundColor: ['rgba(0,113,227,0.2)', 'rgba(255,59,48,0.2)', 'rgba(52,199,89,0.2)', 'rgba(255,149,0,0.2)', 'rgba(90,200,250,0.2)'],
                borderColor: ['#0071e3', '#ff3b30', '#34c759', '#ff9500', '#5ac8fa'],
                borderWidth: 1.5
            }]
        },
        options: {
            responsive: true,
            plugins: { legend: { position: 'bottom', labels: { padding: 8, usePointStyle: true, boxWidth: 10, color: '#86868b' } } },
            scales: { r: { grid: { color: '#e8e8ed' }, ticks: { display: false } } }
        }
    });

    // Live Clock
    function updateClock() {
        const now = new Date();
        const opts = { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric', hour: '2-digit', minute: '2-digit' };
        document.getElementById('liveClock').textContent = now.toLocaleDateString('id-ID', opts);
    }
    updateClock();
    setInterval(updateClock, 30000);
});
</script>
