</div>

<!-- Charts Row 2 -->
<div class="row g-3 mb-4">
    <div class="col-lg-5">
        <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-header bg-white rounded-4 rounded-bottom-0 py-3 border-bottom d-flex justify-content-between align-items-center">
                <h5 class="mb-0"><i class="bi bi-bar-chart-steps text-info"></i> Siswa per Kelas</h5>
                <span class="badge bg-light text-muted">Aktif</span>
            </div>
            <div class="card-body">
                <canvas id="classChart" height="100"></canvas>
            </div>
        </div>
    </div>
    <div class="col-lg-3">
        <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-header bg-white rounded-4 rounded-bottom-0 py-3 border-bottom">
                <h5 class="mb-0"><i class="bi bi-gender-ambiguous text-warning"></i> Gender</h5>
            </div>
            <div class="card-body d-flex align-items-center justify-content-center">
                <canvas id="genderChart" height="100"></canvas>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-header bg-white rounded-4 rounded-bottom-0 py-3 border-bottom">
                <h5 class="mb-0"><i class="bi bi-exclamation-diamond text-danger"></i> Kasus BK Terbanyak</h5>
            </div>
            <div class="card-body">
                <canvas id="bkChart" height="100"></canvas>
            </div>
        </div>
    </div>
</div>

<!-- Aktivity -->
<div class="row">
    <div class="col-12">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-header bg-white rounded-4 rounded-bottom-0 py-3 d-flex justify-content-between align-items-center border-bottom">
                <h5 class="mb-0"><i class="bi bi-activity-log text-secondary"></i> Aktivitas Terbaru</h5>
                <small class="text-muted"><i class="bi bi-clock"></i> Real-time</small>
            </div>
            <div class="card-body p-0">
                <% if (recentLogs.length > 0) { %>
                    <div class="list-group list-group-flush">
                        <% recentLogs.forEach(function(log) { %>
                        <div class="list-group-item border-0 d-flex align-items-center py-3 px-4">
                            <div class="me-3">
                                <div class="avatar-circle bg-<%= ['primary','success','warning','info','danger'][Math.floor(Math.random()*5)] %> text-white d-flex align-items-center justify-content-center" style="width:40px;height:40px;border-radius:50%;">
                                    <i class="bi bi-person-fill"></i>
                                </div>
                            </div>
                            <div class="flex-grow-1">
                                <strong><%= log.full_name %></strong>
                                <span class="badge bg-<%= ['info','success','warning','danger','primary'][Math.floor(Math.random()*5)] %> ms-2"><%= log.action %></span>
                                <br>
                                <small class="text-muted"><%= log.description %></small>
                            </div>
                            <small class="text-muted ms-3 text-nowrap"><%= new Date(log.created_at).toLocaleString('id-ID', {hour:'2-digit',minute:'2-digit'}) %></small>
                        </div>
                        <% }); %>
                    </div>
                <% } else { %>
                    <div class="text-center py-5 text-muted">
                        <i class="bi bi-inbox" style="font-size: 2rem;"></i>
                        <p class="mt-2">Belum ada aktivitas</p>
                    </div>
                <% } %>
            </div>
        </div>
    </div>
</div>

<!-- Chart.js Script -->
<script>
document.addEventListener('DOMContentLoaded', function() {
    // Counter animation
    const counters = document.querySelectorAll('.counter');
    counters.forEach(counter => {
        const target = parseInt(counter.getAttribute('data-target'));
        const duration = 1000;
        const step = Math.ceil(target / (duration / 16));
        let current = 0;
        const update = () => {
            current += step;
            if (current >= target) {
                counter.textContent = target;
                return;
            }
            counter.textContent = current;
            requestAnimationFrame(update);
        };
        update();
    });

    // Color palette (soft, professional)
    const colors = {
        primary: '#667eea',
        success: '#43e97b',
        info: '#4facfe',
        warning: '#f093fb',
        danger: '#f5576c',
        purple: '#a18cd1',
        teal: '#38f9d7',
        pink: '#fa709a'
    };

    // 1. Journal Bar Chart
    const journalCtx = document.getElementById('journalChart').getContext('2d');
    new Chart(journalCtx, {
        type: 'bar',
        data: {
            labels: [<% journalPerMonth.forEach(function(j) { %>'<%= j.month %>',<% }); %>],
            datasets: [{
                label: 'Jurnal',
                data: [<% journalPerMonth.forEach(function(j) { %><%= j.total %>,<% }); %>],
                backgroundColor: ['#667eea', '#4facfe', '#43e97b', '#fa709a', '#f093fb', '#a18cd1'],
                borderRadius: 6,
                borderSkipped: false
            }]
        },
        options: {
            responsive: true,
            plugins: { legend: { display: false } },
            scales: {
                y: { beginAtZero: true, grid: { color: '#f0f0f0' } },
                x: { grid: { display: false } }
            }
        }
    });

    // 2. Student Status Donut Chart
    const statusCtx = document.getElementById('statusChart').getContext('2d');
    new Chart(statusCtx, {
        type: 'doughnut',
        data: {
            labels: [<% studentStatus.forEach(function(s) { %>'<%= s.status %>',<% }); %>],
            datasets: [{
                data: [<% studentStatus.forEach(function(s) { %><%= s.total %>,<% }); %>],
                backgroundColor: ['#43e97b', '#4facfe', '#f093fb', '#f5576c'],
                borderWidth: 0
            }]
        },
        options: {
            responsive: true,
            cutout: '60%',
            plugins: {
                legend: { position: 'bottom', labels: { padding: 12, usePointStyle: true } }
            }
        }
    });

    // 3. Students per Class
    const classCtx = document.getElementById('classChart').getContext('2d');
    new Chart(classCtx, {
        type: 'bar',
        data: {
            labels: [<% studentsPerClass.forEach(function(c) { %>'<%= c.class_name %>',<% }); %>],
            datasets: [{
                label: 'Siswa',
                data: [<% studentsPerClass.forEach(function(c) { %><%= c.total %>,<% }); %>],
                backgroundColor: '#4facfe',
                borderRadius: 4,
                borderSkipped: false
            }]
        },
        options: {
            indexAxis: 'y',
            responsive: true,
            plugins: { legend: { display: false } },
            scales: {
                x: { beginAtZero: true, grid: { color: '#f0f0f0' } },
                y: { grid: { display: false } }
            }
        }
    });

    // 4. Gender Pie Chart
    const genderCtx = document.getElementById('genderChart').getContext('2d');
    const genderData = {
        labels: [],
        datasets: [{
            data: [],
            backgroundColor: ['#4facfe', '#fa709a'],
            borderWidth: 0
        }]
    };
    <% genderCount.forEach(function(g) { %>
        genderData.labels.push('<%= g.gender === "L" ? "Laki-laki" : "Perempuan" %>');
        genderData.datasets[0].data.push(<%= g.total %>);
    <% }); %>
    new Chart(genderCtx, {
        type: 'doughnut',
        data: genderData,
        options: {
            responsive: true,
            cutout: '55%',
            plugins: {
                legend: { position: 'bottom', labels: { padding: 10, usePointStyle: true } }
            }
        }
    });

    // 5. BK Cases by Type
    const bkCtx = document.getElementById('bkChart').getContext('2d');
    new Chart(bkCtx, {
        type: 'polarArea',
        data: {
            labels: [<% casesByType.forEach(function(c) { %>'<%= c.case_type %>',<% }); %>],
            datasets: [{
                data: [<% casesByType.forEach(function(c) { %><%= c.total %>,<% }); %>],
                backgroundColor: ['#667eea88', '#f5576c88', '#43e97b88', '#f093fb88', '#4facfe88'],
                borderColor: ['#667eea', '#f5576c', '#43e97b', '#f093fb', '#4facfe'],
                borderWidth: 1
            }]
        },
        options: {
            responsive: true,
            plugins: {
                legend: { position: 'bottom', labels: { padding: 8, usePointStyle: true, boxWidth: 10 } }
            },
            scales: {
                r: { grid: { color: '#f0f0f0' }, ticks: { display: false } }
            }
        }
    });

    // Live Clock
    function updateClock() {
        const now = new Date();
        const options = { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric', hour: '2-digit', minute: '2-digit', second: '2-digit' };
        document.getElementById('liveClock').textContent = now.toLocaleDateString('id-ID', options);
    }
    updateClock();
    setInterval(updateClock, 1000);
});
</script>
