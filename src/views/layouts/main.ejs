<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <nav class="navbar navbar-expand-lg fixed-top">
        <div class="container-fluid">
            <a class="navbar-brand fw-semibold" href="/dashboard">
                <i class="bi bi-mortarboard-fill me-1"></i> Web Sekolah
            </a>
            <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <% if (user) { %>
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link <%= title === 'Dashboard - Web Sekolah' ? 'fw-semibold' : '' %>" href="/dashboard"><i class="bi bi-speedometer2 me-1"></i> Dashboard</a>
                    </li>
                    <% if (user.role_name === 'admin') { %>
                    <li class="nav-item">
                        <a class="nav-link" href="/users"><i class="bi bi-people-fill me-1"></i> Pengguna</a>
                    </li>
                    <% } %>
                    <% if (['admin','kepala_sekolah','wali_kelas'].includes(user.role_name)) { %>
                    <li class="nav-item">
                        <a class="nav-link" href="/kesiswaan"><i class="bi bi-person-vcard-fill me-1"></i> Kesiswaan</a>
                    </li>
                    <% } %>
                    <% if (['guru','admin','kepala_sekolah','wali_kelas'].includes(user.role_name)) { %>
                    <li class="nav-item">
                        <a class="nav-link" href="/jurnal"><i class="bi bi-journal-bookmark-fill me-1"></i> Jurnal</a>
                    </li>
                    <% } %>
                    <% if (['guru_bk','admin','kepala_sekolah'].includes(user.role_name)) { %>
                    <li class="nav-item">
                        <a class="nav-link" href="/bk"><i class="bi bi-heart-pulse-fill me-1"></i> BK</a>
                    </li>
                    <% } %>
                    <% if (['admin','guru','wali_kelas','kepala_sekolah'].includes(user.role_name)) { %>
                    <li class="nav-item">
                        <a class="nav-link" href="/absensi"><i class="bi bi-calendar-check-fill me-1"></i> Absensi</a>
                    </li>
                    <% } %>
                </ul>
                <ul class="navbar-nav">
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle d-flex align-items-center" href="#" role="button" data-bs-toggle="dropdown">
                            <span class="bg-light rounded-circle d-inline-flex align-items-center justify-content-center me-2" style="width:28px;height:28px;font-size:0.8rem;">
                                <i class="bi bi-person"></i>
                            </span>
                            <span><%= user.full_name %></span>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end shadow-sm">
                            <li><span class="dropdown-item-text" style="font-size:0.8rem;color:var(--apple-gray-600);"><%= user.role_name %></span></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item" href="/profile"><i class="bi bi-person-gear me-2"></i>Profil</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item" href="/auth/logout"><i class="bi bi-box-arrow-right me-2"></i>Logout</a></li>
                        </ul>
                    </li>
                </ul>
                <% } %>
            </div>
        </div>
    </nav>

    <div class="container-fluid" style="padding-top: 80px;">
        <% if (success_msg.length > 0) { %>
            <% success_msg.forEach(function(msg) { %>
                <div class="alert alert-success alert-dismissible fade show d-flex align-items-center">
                    <i class="bi bi-check-circle-fill me-2"></i> <%= msg %>
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            <% }); %>
        <% } %>
        <% if (error_msg.length > 0) { %>
            <% error_msg.forEach(function(msg) { %>
                <div class="alert alert-danger alert-dismissible fade show d-flex align-items-center">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i> <%= msg %>
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            <% }); %>
        <% } %>

        <%- body %>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
    <script src="/js/script.js"></script>
    <script src="/js/search-suggest.js"></script>
</body>
</html>
