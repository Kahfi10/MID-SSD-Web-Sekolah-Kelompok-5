<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-1">Rekap Jurnal Mengajar</h4>
        <p class="text-muted mb-0" style="font-size:0.85rem;">Ringkasan aktivitas pembelajaran</p>
    </div>
    <a href="/jurnal" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Kembali</a>
</div>

<div class="card mb-4">
    <div class="card-body">
        <form method="GET" class="row g-2 align-items-end">
            <div class="col-md-3">
                <label class="form-label">Guru</label>
                <select name="teacher_id" class="form-select">
                    <option value="">Semua Guru</option>
                    <% teachers.forEach(function(t) { %>
                    <option value="<%= t.id %>" <%= filters.teacher_id == t.id ? 'selected' : '' %>><%= t.full_name %></option>
                    <% }); %>
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label">Kelas</label>
                <select name="class_id" class="form-select">
                    <option value="">Semua Kelas</option>
                    <% classes.forEach(function(c) { %>
                    <option value="<%= c.id %>" <%= filters.class_id == c.id ? 'selected' : '' %>><%= c.grade_level %> - <%= c.class_name %></option>
                    <% }); %>
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label">Dari</label>
                <input type="date" name="start_date" class="form-control" value="<%= filters.start_date || '' %>">
            </div>
            <div class="col-md-2">
                <label class="form-label">Sampai</label>
                <input type="date" name="end_date" class="form-control" value="<%= filters.end_date || '' %>">
            </div>
            <div class="col-md-3 d-flex gap-2">
                <button type="submit" class="btn btn-primary flex-fill"><i class="bi bi-funnel"></i> Filter</button>
                <a href="/jurnal/rekap" class="btn btn-outline-secondary"><i class="bi bi-x-circle"></i></a>
            </div>
        </form>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="stat-card text-center">
            <div class="stat-value"><%= total.total_jurnal %></div>
            <div class="stat-label text-muted">Total Jurnal</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="stat-card text-center">
            <div class="stat-value"><%= total.total_guru %></div>
            <div class="stat-label text-muted">Guru Mengajar</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="stat-card text-center">
            <div class="stat-value"><%= total.total_kelas %></div>
            <div class="stat-label text-muted">Kelas Terisi</div>
        </div>
    </div>
</div>

<div class="row g-3">
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header">
                <h6 class="mb-0">Rekap per Guru</h6>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr>
                                <th>Guru</th>
                                <th class="text-center">Jurnal</th>
                                <th class="text-center">Kelas</th>
                                <th class="text-center">Mapel</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (byTeacher.length > 0) { %>
                                <% byTeacher.forEach(function(t) { %>
                                <tr>
                                    <td><%= t.teacher_name %></td>
                                    <td class="text-center"><span class="badge bg-light text-dark border"><%= t.total %></span></td>
                                    <td class="text-center"><%= t.total_classes %></td>
                                    <td class="text-center"><%= t.total_subjects %></td>
                                </tr>
                                <% }); %>
                            <% } else { %>
                                <tr><td colspan="4" class="text-center text-muted py-4">Belum ada data</td></tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header">
                <h6 class="mb-0">Rekap per Kelas</h6>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr>
                                <th>Kelas</th>
                                <th class="text-center">Total Jurnal</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (byClass.length > 0) { %>
                                <% byClass.forEach(function(c) { %>
                                <tr>
                                    <td><%= c.grade_level %> - <%= c.class_name %></td>
                                    <td class="text-center"><span class="badge bg-light text-dark border"><%= c.total %></span></td>
                                </tr>
                                <% }); %>
                            <% } else { %>
                                <tr><td colspan="2" class="text-center text-muted py-4">Belum ada data</td></tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
