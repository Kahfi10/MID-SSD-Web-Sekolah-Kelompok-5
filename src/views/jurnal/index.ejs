<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-1">Jurnal Mengajar</h4>
        <p class="text-muted mb-0" style="font-size:0.85rem;">Catatan aktivitas pembelajaran harian</p>
    </div>
    <div>
        <% if (['admin','kepala_sekolah','wali_kelas'].includes(userRole)) { %>
        <a href="/jurnal/rekap" class="btn btn-outline-secondary me-2">
            <i class="bi bi-file-earmark-bar-graph"></i> Rekap
        </a>
        <% } %>
        <% if (['guru','admin'].includes(userRole)) { %>
        <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#modalTambah">
            <i class="bi bi-plus-lg"></i> Input Jurnal
        </button>
        <% } %>
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>Tanggal</th>
                        <th>Guru</th>
                        <th>Kelas</th>
                        <th>Mapel</th>
                        <th>Materi</th>
                        <th>Metode</th>
                        <th>Catatan</th>
                        <% if (userRole === 'admin') { %><th class="text-end">Aksi</th><% } %>
                    </tr>
                </thead>
                <tbody>
                    <% if (journals.length > 0) { %>
                        <% journals.forEach(function(j) { %>
                        <tr>
                            <td class="text-nowrap"><%= j.teaching_date %></td>
                            <td><%= j.teacher_name %></td>
                            <td><%= j.class_name %></td>
                            <td><%= j.subject_name %></td>
                            <td><%= j.material %></td>
                            <td><%= j.method || '-' %></td>
                            <td><%= j.notes || '-' %></td>
                            <% if (userRole === 'admin') { %>
                            <td class="text-end">
                                <form action="/jurnal/delete/<%= j.id %>" method="POST" class="d-inline" onsubmit="return confirm('Hapus jurnal ini?')">
                                    <button class="btn btn-sm btn-outline-secondary border-0"><i class="bi bi-trash"></i></button>
                                </form>
                            </td>
                            <% } %>
                        </tr>
                        <% }); %>
                    <% } else { %>
                        <tr><td colspan="<%= userRole === 'admin' ? 8 : 7 %>" class="text-center text-muted py-5">Belum ada jurnal mengajar</td></tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Modal Tambah Jurnal -->
<div class="modal fade" id="modalTambah" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h6 class="modal-title fw-semibold">Input Jurnal Mengajar</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form action="/jurnal/store" method="POST">
                <div class="modal-body">
                    <% if (userRole === 'admin') { %>
                    <div class="mb-3">
                        <label class="form-label">Guru</label>
                        <select name="teacher_id" class="form-select" required>
                            <option value="">-- Pilih Guru --</option>
                            <% teachers.forEach(function(t) { %>
                            <option value="<%= t.id %>"><%= t.full_name %></option>
                            <% }); %>
                        </select>
                    </div>
                    <% } %>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Kelas</label>
                            <select name="class_id" class="form-select" required>
                                <option value="">-- Pilih --</option>
                                <% classes.forEach(function(c) { %>
                                <option value="<%= c.id %>"><%= c.grade_level %> - <%= c.class_name %></option>
                                <% }); %>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Mata Pelajaran</label>
                            <select name="subject_id" class="form-select" required>
                                <option value="">-- Pilih --</option>
                                <% subjects.forEach(function(s) { %>
                                <option value="<%= s.id %>"><%= s.subject_name %></option>
                                <% }); %>
                            </select>
                        </div>
                    </div>
                    <div class="mb-3 mt-3">
                        <label class="form-label">Tanggal Mengajar</label>
                        <input type="date" name="teaching_date" class="form-control" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Materi Pembelajaran</label>
                        <textarea name="material" class="form-control" rows="2" required></textarea>
                    </div>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Metode</label>
                            <input type="text" name="method" class="form-control" placeholder="Ceramah, diskusi, dll">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Catatan</label>
                            <textarea name="notes" class="form-control" rows="1"></textarea>
                        </div>
                    </div>
                    <input type="hidden" name="semester_id" value="<%= semesters.length > 0 ? semesters[0].id : 1 %>">
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Batal</button>
                    <button type="submit" class="btn btn-primary">Simpan</button>
                </div>
            </form>
        </div>
    </div>
</div>
