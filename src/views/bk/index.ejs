<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-1">Bimbingan Konseling</h4>
        <p class="text-muted mb-0" style="font-size:0.85rem;">Kelola data konseling, pelanggaran, dan prestasi siswa</p>
    </div>
    <div class="d-flex gap-2">
        <a href="/bk/rekap" class="btn btn-outline-secondary"><i class="bi bi-file-earmark-bar-graph"></i> Rekap</a>
        <% if (user && (user.role_name === 'guru_bk' || user.role_name === 'admin')) { %>
        <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#modalCase"><i class="bi bi-plus-lg"></i> Kasus</button>
        <button class="btn btn-outline-secondary" data-bs-toggle="modal" data-bs-target="#modalCounseling"><i class="bi bi-plus-lg"></i> Konseling</button>
        <button class="btn btn-outline-secondary" data-bs-toggle="modal" data-bs-target="#modalViolation"><i class="bi bi-plus-lg"></i> Pelanggaran</button>
        <button class="btn btn-outline-secondary" data-bs-toggle="modal" data-bs-target="#modalAchievement"><i class="bi bi-plus-lg"></i> Prestasi</button>
        <% } %>
    </div>
</div>

<div data-search-suggest="/bk/api/search" class="mb-3 position-relative">
    <form method="GET">
        <div class="input-group">
            <input type="text" name="search" class="form-control" placeholder="Cari nama siswa, jenis kasus, pelanggaran, atau prestasi..." value="<%= typeof search !== 'undefined' ? search : '' %>" autocomplete="off">
            <button class="btn btn-primary" type="submit"><i class="bi bi-search"></i></button>
            <% if (typeof search !== 'undefined' && search) { %>
            <a href="/bk" class="btn btn-outline-secondary"><i class="bi bi-x-lg"></i></a>
            <% } %>
        </div>
    </form>
    <div class="search-suggest-dropdown list-group position-absolute w-100 shadow-sm rounded-3 d-none" style="z-index:1000;top:100%;left:0;background:#fff;border:1px solid #e5e5ea;"></div>
</div>
<!-- Kasus -->
<div class="card border-0 shadow-sm rounded-4 mb-3">
    <div class="card-header bg-white rounded-4 rounded-bottom-0 py-3">
        <h5 class="mb-0"><i class="bi bi-exclamation-triangle"></i> Daftar Kasus</h5>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Siswa</th><th>NIS</th><th>Kelas</th><th>Tgl</th><th>Jenis</th><th>Deskripsi</th><th>Status</th><th>Aksi</th>
                    </tr>
                </thead>
                <tbody>
                    <% cases.forEach(function(c) { %>
                    <tr>
                        <td><%= c.student_name %></td>
                        <td><%= c.nis %></td>
                        <td><%= c.class_name || '-' %></td>
                        <td><%= c.case_date %></td>
                        <td><%= c.case_type %></td>
                        <td><%= c.description %></td>
                        <td>
                            <% if (c.status === 'open') { %><span class="badge bg-danger">Open</span>
                            <% } else if (c.status === 'proses') { %><span class="badge bg-warning">Proses</span>
                            <% } else { %><span class="badge bg-success">Selesai</span><% } %>
                        </td>
                        <td>
                            <% if (user && (user.role_name === 'guru_bk' || user.role_name === 'admin')) { %>
                            <div class="d-flex align-items-center gap-1">
                                <form action="/bk/cases/update-status/<%= c.id %>" method="POST" class="m-0">
                                    <select name="status" class="form-select form-select-sm" style="min-width:90px;" onchange="this.form.submit()">
                                        <option value="open" <%= c.status === 'open' ? 'selected' : '' %>>Open</option>
                                        <option value="proses" <%= c.status === 'proses' ? 'selected' : '' %>>Proses</option>
                                        <option value="selesai" <%= c.status === 'selesai' ? 'selected' : '' %>>Selesai</option>
                                    </select>
                                </form>
                                <form action="/bk/cases/delete/<%= c.id %>" method="POST" class="m-0" onsubmit="return confirm('Hapus kasus ini?')">
                                    <button class="btn btn-sm btn-danger"><i class="bi bi-trash"></i></button>
                                </form>
                            </div>
                            <% } else { %>
                            <span class="badge bg-secondary"><%= c.status %></span>
                            <% } %>
                        </td>
                    </tr>
                    <% }); %>
                </tbody>
            </table>
        </div>
        <% if (totalPages > 1) { %>
        <nav class="mt-1">
            <ul class="pagination pagination-sm justify-content-end mb-0">
                <% if (page > 1) { %>
                <li class="page-item"><a class="page-link" href="?search=<%= typeof search !== 'undefined' ? search : '' %>&page=<%= page - 1 %>">«</a></li>
                <% } %>
                <% for (let p = 1; p <= totalPages; p++) { %>
                <li class="page-item <%= p === page ? 'active' : '' %>"><a class="page-link" href="?search=<%= typeof search !== 'undefined' ? search : '' %>&page=<%= p %>"><%= p %></a></li>
                <% } %>
                <% if (page < totalPages) { %>
                <li class="page-item"><a class="page-link" href="?search=<%= typeof search !== 'undefined' ? search : '' %>&page=<%= page + 1 %>">»</a></li>
                <% } %>
            </ul>
        </nav>
        <% } %>
    </div>
</div>

<!-- Konseling -->
<div class="card border-0 shadow-sm rounded-4 mb-3">
    <div class="card-header bg-white rounded-4 rounded-bottom-0 py-3">
        <h5 class="mb-0"><i class="bi bi-chat-dots"></i> Catatan Konseling</h5>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Siswa</th><th>NIS</th><th>Tanggal</th><th>Topik</th><th>Catatan</th><th>Tindak Lanjut</th><th>Aksi</th>
                    </tr>
                </thead>
                <tbody>
                    <% counseling.forEach(function(c) { %>
                    <tr>
                        <td><%= c.student_name %></td>
                        <td><%= c.nis %></td>
                        <td><%= c.counseling_date %></td>
                        <td><%= c.topic %></td>
                        <td><%= c.note %></td>
                        <td><%= c.follow_up || '-' %></td>
                        <td>
                            <form action="/bk/counseling/delete/<%= c.id %>" method="POST" class="d-inline" onsubmit="return confirm('Hapus catatan konseling ini?')">
                                <button class="btn btn-sm btn-danger"><i class="bi bi-trash"></i></button>
                            </form>
                        </td>
                    </tr>
                    <% }); %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Pelanggaran -->
<div class="card border-0 shadow-sm rounded-4 mb-3">
    <div class="card-header bg-white rounded-4 rounded-bottom-0 py-3">
        <h5 class="mb-0"><i class="bi bi-shield-exclamation"></i> Pelanggaran Siswa</h5>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Siswa</th><th>NIS</th><th>Tanggal</th><th>Jenis</th><th>Deskripsi</th><th>Sanksi</th><th>Aksi</th>
                    </tr>
                </thead>
                <tbody>
                    <% violations.forEach(function(v) { %>
                    <tr>
                        <td><%= v.student_name %></td>
                        <td><%= v.nis %></td>
                        <td><%= v.violation_date %></td>
                        <td><%= v.violation_type %></td>
                        <td><%= v.description %></td>
                        <td><%= v.sanction || '-' %></td>
                        <td>
                            <form action="/bk/violations/delete/<%= v.id %>" method="POST" class="d-inline" onsubmit="return confirm('Hapus pelanggaran ini?')">
                                <button class="btn btn-sm btn-danger"><i class="bi bi-trash"></i></button>
                            </form>
                        </td>
                    </tr>
                    <% }); %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Prestasi -->
<div class="card border-0 shadow-sm rounded-4 mb-3">
    <div class="card-header bg-white rounded-4 rounded-bottom-0 py-3">
        <h5 class="mb-0"><i class="bi bi-trophy"></i> Prestasi Siswa</h5>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Siswa</th><th>NIS</th><th>Tanggal</th><th>Prestasi</th><th>Tingkat</th><th>Keterangan</th><th>Aksi</th>
                    </tr>
                </thead>
                <tbody>
                    <% achievements.forEach(function(a) { %>
                    <tr>
                        <td><%= a.student_name %></td>
                        <td><%= a.nis %></td>
                        <td><%= a.achievement_date %></td>
                        <td><%= a.achievement_name %></td>
                        <td><%= a.level || '-' %></td>
                        <td><%= a.description || '-' %></td>
                        <td>
                            <form action="/bk/achievements/delete/<%= a.id %>" method="POST" class="d-inline" onsubmit="return confirm('Hapus prestasi ini?')">
                                <button class="btn btn-sm btn-danger"><i class="bi bi-trash"></i></button>
                            </form>
                        </td>
                    </tr>
                    <% }); %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Modal Kasus -->
<div class="modal fade" id="modalCase" tabindex="-1"><div class="modal-dialog"><div class="modal-content">
    <div class="modal-header"><h5 class="modal-title">Catat Kasus Baru</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
    <form action="/bk/cases/store" method="POST"><div class="modal-body">
        <div class="mb-3"><label class="form-label">Siswa</label>
            <select name="student_id" class="form-control" required>
                <option value="">-- Pilih Siswa --</option>
                <% students.forEach(function(s) { %>
                <option value="<%= s.id %>"><%= s.nis %> - <%= s.full_name %></option>
                <% }); %>
            </select>
        </div>
        <% if (user && user.role_name === 'admin') { %>
        <div class="mb-3"><label class="form-label">Guru BK</label>
            <select name="teacher_id" class="form-control" required>
                <option value="">-- Pilih Guru BK --</option>
                <% teachers.forEach(function(t) { %>
                <option value="<%= t.id %>"><%= t.full_name %></option>
                <% }); %>
            </select>
        </div>
        <% } %>
        <div class="mb-3"><label class="form-label">Tanggal</label><input type="date" name="case_date" class="form-control" required></div>
        <div class="mb-3"><label class="form-label">Jenis Kasus</label><input type="text" name="case_type" class="form-control" required></div>
        <div class="mb-3"><label class="form-label">Deskripsi</label><textarea name="description" class="form-control" rows="2" required></textarea></div>
    </div><div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Batal</button>
        <button type="submit" class="btn btn-primary">Simpan</button>
    </div></form>
</div></div></div>

