<div class="d-flex justify-content-between align-items-center mb-3">
    <h4><i class="bi bi-people-fill"></i> Manajemen Pengguna</h4>
    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#modalTambah">
        <i class="bi bi-plus-lg"></i> Tambah User
    </button>
</div>

<div class="card border-0 shadow-sm rounded-4">
    <div class="card-body">
        <div data-search-suggest="/users/api/search" class="mb-3 position-relative">
            <form method="GET">
                <div class="input-group">
                    <input type="text" name="search" class="form-control" placeholder="Cari username, nama, atau email..." value="<%= typeof search !== 'undefined' ? search : '' %>" autocomplete="off">
                    <button class="btn btn-primary" type="submit"><i class="bi bi-search"></i></button>
                    <% if (typeof search !== 'undefined' && search) { %>
                    <a href="/users" class="btn btn-outline-secondary"><i class="bi bi-x-lg"></i></a>
                    <% } %>
                </div>
            </form>
            <div class="search-suggest-dropdown list-group position-absolute w-100 shadow-sm rounded-3 d-none" style="z-index:1000;top:100%;left:0;"></div>
        </div>
        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Username</th>
                        <th>Nama Lengkap</th>
                        <th>Email</th>
                        <th>Role</th>
                        <th>Status</th>
                        <th>Terakhir Login</th>
                        <th>Aksi</th>
                    </tr>
                </thead>
                <tbody>
                    <% users.forEach(function(u) { %>
                    <tr>
                        <td><%= u.username %></td>
                        <td><%= u.full_name %></td>
                        <td><%= u.email %></td>
                        <td><span class="badge bg-secondary"><%= u.role_name %></span></td>
                        <td>
                            <% if (u.is_active) { %>
                                <span class="badge bg-success">Aktif</span>
                            <% } else { %>
                                <span class="badge bg-danger">Nonaktif</span>
                            <% } %>
                        </td>
                        <td><small class="text-muted"><%= u.last_login || 'Belum pernah' %></small></td>
                        <td>
                            <a href="/users/edit/<%= u.id %>" class="btn btn-sm btn-warning" title="Edit"><i class="bi bi-pencil"></i></a>
                            <form action="/users/reset-password/<%= u.id %>" method="POST" class="d-inline" onsubmit="return confirm('Reset password user <%= u.username %> ke default?')">
                                <button class="btn btn-sm btn-info" title="Reset Password"><i class="bi bi-key"></i></button>
                            </form>
                            <form action="/users/delete/<%= u.id %>" method="POST" class="d-inline" onsubmit="return confirm('Hapus user ini?')">
                                <button class="btn btn-sm btn-danger"><i class="bi bi-trash"></i></button>
                            </form>
                        </td>
                    </tr>
                    <% }); %>
                </tbody>
            </table>
        </div>
        <% if (totalPages > 1) { %>
        <nav class="mt-3">
            <ul class="pagination pagination-sm justify-content-end mb-0">
                <% if (page > 1) { %>
                <li class="page-item"><a class="page-link" href="?search=<%= typeof search !== 'undefined' ? search : '' %>&page=<%= page - 1 %>">«</a></li>
                <% } %>
                <% for (let p = 1; p <= totalPages; p++) { %>
                <li class="page-item <%= p === page ? 'active' : '' %>"><a class="page-link" href="?search=<%= typeof search !== 'undefined' ? search : '' %>&page=<%= p %>"><%= p %></a></li>
                <% } %>
                <% if (page < totalPages) { %>
                <li class="page-item"><a class="page-link" href="?search=<%= typeof search !== 'undefined' ? search : '' %>&page=<%= page + 1 %>">»</a></li>
                <% } %>
            </ul>
        </nav>
        <% } %>
    </div>
</div>

<!-- Modal Tambah User -->
<div class="modal fade" id="modalTambah" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Tambah Pengguna Baru</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form action="/users/store" method="POST">
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Username</label>
                        <input type="text" name="username" class="form-control" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Nama Lengkap</label>
                        <input type="text" name="full_name" class="form-control" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Email</label>
                        <input type="email" name="email" class="form-control" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Password</label>
                        <input type="password" name="password" class="form-control" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Role</label>
                        <select name="role_id" class="form-control" required>
                            <% roles.forEach(function(r) { %>
                            <option value="<%= r.id %>"><%= r.name %></option>
                            <% }); %>
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Batal</button>
                    <button type="submit" class="btn btn-primary">Simpan</button>
                </div>
            </form>
        </div>
    </div>
</div>
